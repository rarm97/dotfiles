[core]
	excludesfile = ~/.config/git/ignore
	editor = nvim
[user]
	name = Richard Armstrong
	email = rarm97@pm.me
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultBranch = main
[pull]
	rebase = true
[rerere]
	enabled = true
[diff]
	algorithm = histogram
[merge]
	conflictstyle = zdiff3
