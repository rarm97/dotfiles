#!/usr/bin/env bash
# Kill the current tmux session without closing WezTerm.
# If it's the last session, creates a new one first.

name="$(tmux display-message -p '#{session_name}')"
count="$(tmux list-sessions 2>/dev/null | wc -l | xargs)"

if [ "$count" -le 1 ]; then
    tmux new-session -d
fi

tmux switch-client -n
tmux kill-session -t "=$name"
